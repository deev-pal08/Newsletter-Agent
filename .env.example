# === REQUIRED ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RESEND_API_KEY=your_resend_api_key_here

# === DISCOVERY (Tavily) ===
# Required for web discovery (scan command). Free tier: 1,000 queries/month.
# Get key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# === SEMANTIC DEDUPLICATION (OpenAI Embeddings) ===
# Required for semantic dedup. text-embedding-3-small costs ~$0.003/run.
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# === RELEVANCE FILTERING (DeepSeek) ===
# Required for pre-ranking noise filter. V4 Flash costs ~$0.025/run.
# Get key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# === ARTICLE EXTRACTION (Firecrawl) — OPTIONAL ===
# Only needed for JavaScript-heavy sites that Jina Reader can't handle.
# If not set, falls back to Claude Haiku. Free tier: 500 pages/month.
# Get key at: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

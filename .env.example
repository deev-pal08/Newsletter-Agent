# === REQUIRED ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RESEND_API_KEY=your_resend_api_key_here

# === WEB ARTICLE DISCOVERY (Tavily) ===
# Searches the web for fresh articles matching your profile. Free tier: 1,000 queries/month.
# Get key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# === SEMANTIC DEDUPLICATION (OpenAI Embeddings) ===
# Cross-source dedup via embeddings. text-embedding-3-small costs ~$0.003/run.
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# === RELEVANCE FILTERING & CLASSIFICATION (DeepSeek) ===
# Pre-ranking noise filter. DeepSeek V4 Flash costs ~$0.0003/run.
# Also used for:
#   - Targeted search query generation for Deep Search Engine
#   - LLM classification of search results (article vs index page)
#   - Auto-discovery of index pages for resource database
# Get key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# === WEB PAGE EXTRACTION (Firecrawl) — OPTIONAL ===
# Only needed for JavaScript-heavy sites that Jina Reader can't handle.
# If not set, falls back to Claude Haiku. Free tier: 1,000 credits/month.
# Get key at: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# === DEEP SEARCH ENGINE ===

# Layer 1B — Exa Neural Search (semantic web search)
# Free: 1,000 requests/month. Get key at: https://exa.ai
EXA_API_KEY=your_exa_api_key_here

# Layer 2 — Perplexity Sonar Deep Research (autonomous multi-step research)
# Cost: ~$0.41–$1.32 per research query. 4 queries per scan = ~$1.65–$5.28/scan
# Get key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Layer 3 — GPT Researcher uses existing ANTHROPIC_API_KEY + TAVILY_API_KEY
# No additional key needed. DeepSeek key needed for fast_llm:
# DEEPSEEK_API_KEY is already set above if you followed the previous setup
